// CivicFix database schema
// Default datasource is SQLite for zero-config local/dev use.
// Swap provider to "postgresql" and set DATABASE_URL to a Postgres
// connection string (e.g. Neon/Supabase) for production — no model
// changes are required, SQLite and Postgres both work with this schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model User {
  id            String    @id @default(uuid())
  fullName      String
  email         String    @unique
  password      String
  phone         String?
  avatar        String?
  address       String?
  role          String    @default("CITIZEN")
  isVerified    Boolean   @default(false)
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reports       Report[]
  comments      Comment[]
  notifications Notification[]
  savedReports  SavedReport[]

  @@map("users")
}

model Category {
  id      String  @id @default(uuid())
  name    String  @unique
  icon    String?
  color   String?
  reports Report[]

  @@map("categories")
}

model Department {
  id             String   @id @default(uuid())
  departmentName String
  email          String?
  phone          String?
  reports        Report[]

  @@map("departments")
}

model Report {
  id           String       @id @default(uuid())
  title        String
  description  String
  category     Category     @relation(fields: [categoryId], references: [id])
  categoryId   String
  priority     String       @default("MEDIUM")
  status       String       @default("PENDING")
  latitude     Float
  longitude    Float
  address      String?
  images       String       @default("[]") // JSON-encoded array of image URLs
  isAnonymous  Boolean      @default(false)
  user         User?        @relation(fields: [userId], references: [id])
  userId       String?
  department   Department?  @relation(fields: [departmentId], references: [id])
  departmentId String?
  aiSummary    String?
  aiCategory   String?
  aiPriority   String?
  aiRecommendation String?
  aiStatus     String       @default("PENDING")
  aiAnalyzedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  comments      Comment[]
  savedBy       SavedReport[]
  timelineEvents TimelineEvent[]

  @@map("reports")
}

model TimelineEvent {
  id        String   @id @default(uuid())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  status    String
  note      String?
  createdAt DateTime @default(now())

  @@map("timeline_events")
}

model Comment {
  id        String   @id @default(uuid())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  comment   String
  createdAt DateTime @default(now())

  @@map("comments")
}

model SavedReport {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
  @@map("saved_reports")
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}


